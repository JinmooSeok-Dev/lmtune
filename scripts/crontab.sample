# /etc/cron.d/bench-nightly 또는 `crontab -e` 에 복사.
# 매일 03:00 에 llm-d endpoint 에 대해 전체 profile sweep.
#
# 사용 전 BENCH_HOME, LLMD_API_KEY, USER 를 환경에 맞게 채우세요.

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
BENCH_HOME=/path/to/your/lmtune-clone   # e.g. /home/$USER/ml_ai/benchmark
LLMD_API_KEY=replace-me

0 3 * * * YOUR_USERNAME cd $BENCH_HOME && ENDPOINT=configs/endpoints/llmd_k8s.yaml \
    ./scripts/nightly_sweep.sh >> $BENCH_HOME/data/reports/cron.log 2>&1
