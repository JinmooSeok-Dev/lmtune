<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ study.name }} — bench autotuner</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body class="bg-slate-50 text-slate-800">
<header class="bg-white border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-6 py-5">
    <div class="flex items-center gap-3 text-sm text-slate-500 mb-2">
      <a href="../index.html" class="text-blue-600 hover:underline">← all studies</a>
      <span class="text-slate-300">/</span>
      <a href="../compare.html" class="text-blue-600 hover:underline">compare</a>
    </div>
    <h1 class="text-2xl font-bold tracking-tight">{{ study.name }}</h1>
    <div class="text-slate-500 text-sm mt-1 font-mono">{{ study.study_id }}</div>
    <div class="mt-3 grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
      <div><span class="text-slate-400">strategy</span> <span class="font-mono">{{ study.strategy }}</span></div>
      <div><span class="text-slate-400">model</span> {{ study.model or '?' }}</div>
      <div><span class="text-slate-400">HW</span> {{ study.hw or study.endpoint_slug or '?' }}</div>
      <div><span class="text-slate-400">status</span> <span class="font-mono">{{ study.status }}</span></div>
      <div><span class="text-slate-400">objective</span> <span class="font-mono">{{ study.direction }} {{ study.metric_name }}</span></div>
      <div>
        <span class="text-slate-400">trials</span>
        {{ study.n_completed }}/{{ study.n_trials }}
        ({{ study.n_pruned }} pruned{% if study.n_infeasible %},
          <span class="text-rose-600 font-mono">{{ study.n_infeasible }} infeasible</span>{% endif %})
      </div>
      <div><span class="text-slate-400">top score</span> <span class="font-bold">{% if study.top_score is not none %}{{ "%.4f"|format(study.top_score) }}{% else %}—{% endif %}</span></div>
      <div><span class="text-slate-400">created</span> <span class="font-mono text-xs">{{ study.created_at or '—' }}</span></div>
      {% if study.n_axes %}
      <div><span class="text-slate-400">axes</span> <span class="font-mono">{{ study.n_axes }}</span></div>
      {% endif %}
      {% if study.pareto_front %}
      <div><span class="text-slate-400">Pareto</span> <span class="font-mono text-rose-600">{{ study.pareto_front|length }}</span> non-dominated</div>
      {% endif %}
    </div>
  </div>
</header>

<main class="max-w-7xl mx-auto px-6 py-6 space-y-6">

  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-3">Top-1 winning params</h2>
    {% if study.top_params %}
    <pre class="text-xs bg-slate-50 p-3 rounded overflow-auto">{{ study.top_params|tojson(indent=2) }}</pre>
    <p class="mt-3 text-xs text-slate-500">
      Export this as a self-contained recipe: <code>bench search export {{ study.study_id }} --winner top-1 --out b200/results/{{ study.study_id }}/winner</code>
    </p>
    {% else %}
    <p class="text-slate-500">No completed trials yet.</p>
    {% endif %}
  </section>

  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-3">Trial scatter — choose any X / Y</h2>
    <div class="flex flex-wrap gap-3 items-center mb-3 text-xs">
      <label>X axis
        <select id="x-axis" class="ml-1 border border-slate-300 rounded px-2 py-1 font-mono"></select>
      </label>
      <label>Y axis
        <select id="y-axis" class="ml-1 border border-slate-300 rounded px-2 py-1 font-mono"></select>
      </label>
      <span class="text-slate-400">
        Color = trial sequence (lighter → newer).
        Hover for trial_id.
      </span>
    </div>
    <div id="tput-empty" class="hidden text-sm text-slate-500 bg-amber-50 border border-amber-200 rounded p-3">
      <strong>차트 데이터 없음.</strong> 이 study 는 (1) completed trial 이 없거나 (2) trial_metrics 에
      X·Y 측정값이 기록되지 않았습니다. <code>bench search status {{ study.study_id }}</code> 로 trial
      상태를 확인해 보세요.
    </div>
    <canvas id="throughput-vs-ttft" width="800" height="380"></canvas>
    {% if study.pareto_front %}
    <p class="mt-2 text-xs text-rose-600">
      🔴 빨간 곡선 = Pareto 비지배 front (TTFT p99 ↓ × throughput ↑). {{ study.pareto_front|length }} point.
      X/Y 축이 ttft_p99 / throughput_* 일 때만 표시.
    </p>
    {% endif %}
  </section>

  {% if study.axis_importance %}
  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-1">Axis importance — RandomForest</h2>
    <p class="text-xs text-slate-500 mb-3">
      score 를 회귀로 fitting 한 RandomForest 의 feature importance. <span class="text-rose-600">drop</span> = 5% 미만
      → 다음 study 의 search-space 에서 freeze 권고. 표본이 corner 에 치우치면 이 추정도 편향됩니다 — heuristic 으로만.
    </p>
    <canvas id="axis-importance-bar" height="{{ 30 + 22 * (study.axis_importance | length) }}"></canvas>
    <details class="mt-3 text-xs">
      <summary class="cursor-pointer text-slate-500">raw 표</summary>
      <table class="mt-2 text-xs w-full">
        <thead class="bg-slate-50 text-slate-700">
          <tr>
            <th class="text-left p-1.5">axis</th>
            <th class="text-right p-1.5">importance</th>
            <th class="text-left p-1.5">recommendation</th>
          </tr>
        </thead>
        <tbody>
        {% for r in study.axis_importance %}
          <tr class="border-t border-slate-100">
            <td class="p-1.5 font-mono">{{ r.axis }}</td>
            <td class="p-1.5 text-right font-mono">{{ "%.4f"|format(r.importance) }}</td>
            <td class="p-1.5 {% if r.recommendation == 'drop' %}text-rose-600{% else %}text-emerald-700{% endif %}">{{ r.recommendation }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </details>
  </section>
  {% endif %}

  {% if study.points and (study.points | selectattr('score') | list | length) >= 2 %}
  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-1">Parallel coordinates — top-K vs rest</h2>
    <p class="text-xs text-slate-500 mb-3">
      각 axis 가 수직선. trial 1개 = axis 들을 잇는 polyline. <strong>top-K</strong> 는 진하게,
      나머지는 연한 회색. 13+ axis 의 macro 공간을 한눈에 비교 (B5 combined Pareto study 등).
    </p>
    <div class="flex items-center gap-3 mb-2 text-xs">
      <label>top-K
        <input id="pc-topk" type="number" min="1" max="20" value="5" class="ml-1 w-16 border border-slate-300 rounded px-2 py-0.5 font-mono">
      </label>
      <label>max axes
        <input id="pc-maxax" type="number" min="3" max="30" value="14" class="ml-1 w-16 border border-slate-300 rounded px-2 py-0.5 font-mono">
      </label>
      <span class="text-slate-400">hover trial 표시. 카테고리 axis 는 정수 매핑.</span>
    </div>
    <canvas id="parallel-coords" width="900" height="360"></canvas>
  </section>

  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-1">Axis-pair score heatmap</h2>
    <p class="text-xs text-slate-500 mb-3">
      두 axis 를 골라 trial 점수를 색으로. 같은 cell 에 여러 trial 있으면 평균.
      <strong>밝은 색 = 높은 score</strong>. score 가 어느 axis 조합에서 좋은지 빠르게 비교.
    </p>
    <div class="flex flex-wrap gap-3 items-center mb-3 text-xs">
      <label>X axis (axis name)
        <select id="hm-x" class="ml-1 border border-slate-300 rounded px-2 py-1 font-mono"></select>
      </label>
      <label>Y axis
        <select id="hm-y" class="ml-1 border border-slate-300 rounded px-2 py-1 font-mono"></select>
      </label>
      <span class="text-slate-400">N=trial 수, 셀 hover 시 표시.</span>
    </div>
    <canvas id="axis-pair-heatmap" width="900" height="420"></canvas>
  </section>
  {% endif %}

  {% set top_pt = study.points | selectattr('score') | sort(attribute='score', reverse=True) | list | first %}
  {% if top_pt and top_pt.metrics %}
  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-3">Top-1 metrics — per workload</h2>
    <p class="text-xs text-slate-500 mb-3">winner (seq={{ top_pt.seq }}) 의 모든 trial_metric (workload 별).</p>
    <div class="overflow-auto">
      <table class="text-xs">
        <thead class="bg-slate-100 text-slate-700">
          <tr>
            <th class="text-left p-2">metric.workload</th>
            <th class="text-right p-2">value</th>
          </tr>
        </thead>
        <tbody>
        {% for k in top_pt.metrics.keys() | sort %}
          <tr class="border-t border-slate-100">
            <td class="p-2 font-mono">{{ k }}</td>
            <td class="p-2 text-right font-mono">{{ "%.4g"|format(top_pt.metrics[k]) }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-3">Score over trials</h2>
    <div id="score-empty" class="hidden text-sm text-slate-500 bg-amber-50 border border-amber-200 rounded p-3">
      <strong>점수 데이터 없음.</strong> completed trial 이 없거나 score 가 기록되지 않은 study 입니다.
    </div>
    <canvas id="score-trace" width="800" height="280"></canvas>
  </section>

  {% if study.axis_diff and study.axis_diff|length > 1 %}
  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-1">왜 이 winner 가 골라졌나 — top-K axis 차이</h2>
    <p class="text-xs text-slate-500 mb-3">
      score 상위 trial 들이 winner 와 어느 axis 에서 갈렸는지. 같은 값은 표시되지 않음 — 그 axis 는 winner 결정에 영향을 주지 않았을 가능성이 큼.
    </p>
    <div class="overflow-auto">
      <table class="text-xs w-full">
        <thead class="bg-slate-100 text-slate-700">
          <tr>
            <th class="text-left p-2">rank</th>
            <th class="text-left p-2">seq</th>
            <th class="text-right p-2">score</th>
            <th class="text-left p-2">axis 차이 (winner → this)</th>
          </tr>
        </thead>
        <tbody>
        {% for row in study.axis_diff %}
          <tr class="border-t border-slate-100 {% if row.is_winner %}bg-amber-50{% endif %}">
            <td class="p-2 font-mono">{% if row.is_winner %}🏆 #1{% else %}#{{ loop.index }}{% endif %}</td>
            <td class="p-2 font-mono">{{ row.seq }}</td>
            <td class="p-2 text-right font-mono">{{ "%.3f"|format(row.score) }}</td>
            <td class="p-2 font-mono">
              {% if row.is_winner %}
                <span class="text-slate-400">— (reference)</span>
              {% elif row.diff %}
                {% for k, vp in row.diff.items() %}
                  <span class="inline-block px-1.5 py-0.5 mr-1 mb-1 rounded bg-slate-100 text-slate-700">
                    <strong>{{ k }}</strong>: {{ vp[0] }} → {{ vp[1] }}
                  </span>
                {% endfor %}
              {% else %}
                <span class="text-slate-400">(identical params)</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
  {% endif %}

  <section class="bg-white border border-slate-200 rounded-lg p-5">
    <h2 class="text-lg font-semibold mb-3">Trial table</h2>
    <div class="overflow-auto">
      <table class="text-xs w-full">
        <thead class="bg-slate-100 text-slate-700">
          <tr>
            <th class="text-left p-2">seq</th>
            <th class="text-left p-2">trial_id</th>
            <th class="text-left p-2">status</th>
            <th class="text-left p-2">why?</th>
            <th class="text-right p-2">score</th>
            <th class="text-right p-2">throughput tok/s</th>
            <th class="text-right p-2">ttft p99 (ms)</th>
            <th class="text-right p-2">e2e p99 (s)</th>
            <th class="text-right p-2">CV</th>
            <th class="text-left p-2">params</th>
          </tr>
        </thead>
        <tbody>
        {% for p in study.points %}
          <tr class="border-t border-slate-100 hover:bg-slate-50">
            <td class="p-2 font-mono">{{ p.seq }}</td>
            <td class="p-2 font-mono text-slate-500">{{ p.trial_id[:10] }}…</td>
            <td class="p-2">
              <span class="text-xs px-1.5 py-0.5 rounded
                {% if p.status == 'completed' %}bg-green-100 text-green-800
                {% elif p.status == 'pruned' %}bg-amber-100 text-amber-800
                {% else %}bg-slate-100 text-slate-700{% endif %}">{{ p.status }}</span>
            </td>
            <td class="p-2 text-xs">
              {% if p.reasoning %}
                <span class="font-mono text-slate-600">{{ p.reasoning.phase }}</span>
                <span class="text-slate-400">·</span>
                <span class="{% if '🟢' in p.reasoning.outcome %}text-green-700 font-semibold{% else %}text-slate-500{% endif %}">{{ p.reasoning.outcome }}</span>
                {% if p.reasoning.delta_pct_vs_best is not none and p.reasoning.delta_pct_vs_best != 0 %}
                <span class="text-slate-400 font-mono">({{ "%+.1f"|format(p.reasoning.delta_pct_vs_best) }}%)</span>
                {% endif %}
              {% else %}—{% endif %}
            </td>
            <td class="p-2 text-right font-mono">{% if p.score is not none %}{{ "%.3f"|format(p.score) }}{% else %}—{% endif %}</td>
            <td class="p-2 text-right font-mono">{% if p.throughput_avg is not none %}{{ "%.1f"|format(p.throughput_avg) }}{% else %}—{% endif %}</td>
            <td class="p-2 text-right font-mono">{% if p.ttft_p99 is not none %}{{ "%.0f"|format(p.ttft_p99) }}{% else %}—{% endif %}</td>
            <td class="p-2 text-right font-mono">{% if p.e2e_p99 is not none %}{{ "%.2f"|format(p.e2e_p99) }}{% else %}—{% endif %}</td>
            <td class="p-2 text-right font-mono">{% if p.cv is not none %}{{ "%.3f"|format(p.cv) }}{% else %}—{% endif %}</td>
            <td class="p-2 text-xs font-mono text-slate-600">{{ p.params|tojson }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <details class="bg-white border border-slate-200 rounded-lg p-5" id="principles-panel">
    <summary class="cursor-pointer text-sm font-semibold text-slate-700">📚 Search principles — 왜 이 sampler 가 이렇게 결정하는가</summary>
    <div class="mt-4 grid md:grid-cols-2 gap-5 text-xs leading-relaxed text-slate-700">
      <div class="border-l-2 border-blue-300 pl-3">
        <h3 class="font-semibold text-slate-800 mb-1">TPE (Tree-structured Parzen Estimator)</h3>
        <p>과거 trial 을 score 분위로 <strong>good (top γ%)</strong> vs <strong>bad</strong> 로 가른 뒤, Parzen window 로 분포 <code>l(x) / g(x)</code> 추정. ratio 가 큰 후보를 다음 trial 로.</p>
        <p class="text-slate-500 mt-1">처음 ~10개는 random warmup. 그 후 "exploit" — 좋았던 영역의 분포를 닮은 점.</p>
      </div>
      <div class="border-l-2 border-purple-300 pl-3">
        <h3 class="font-semibold text-slate-800 mb-1">NSGA-II (multi-objective)</h3>
        <p>매 generation 에서 (1) <strong>non-dominated sort</strong> 로 trial 을 front 계층화, (2) crowding distance 로 다양성 우선. Pareto front 를 따라 골고루.</p>
        <p class="text-slate-500 mt-1">"TTFT 낮은 점" vs "throughput 높은 점" 사이 빈 구간을 채우려 함.</p>
      </div>
      <div class="border-l-2 border-green-300 pl-3">
        <h3 class="font-semibold text-slate-800 mb-1">CMA-ES (continuous)</h3>
        <p>multivariate Gaussian <code>N(m, σ² C)</code> 에서 후보를 뽑고, 상위 점들로 평균 <code>m</code>, covariance <code>C</code>, step <code>σ</code> 를 갱신.</p>
        <p class="text-slate-500 mt-1">"어느 방향이 score 를 올리는지" covariance 가 학습.</p>
      </div>
      <div class="border-l-2 border-amber-300 pl-3">
        <h3 class="font-semibold text-slate-800 mb-1">Sobol total-order (sensitivity)</h3>
        <p><code>bench search sensitivity &lt;study&gt;</code> — 각 axis 가 출력 분산의 몇 % 를 설명하는지. 0.05 미만이면 freeze 권고.</p>
        <p class="text-slate-500 mt-1">"이 axis 를 고정해도 점수가 바뀔까?" 의 통계적 답.</p>
      </div>
      <div class="border-l-2 border-rose-300 pl-3 md:col-span-2">
        <h3 class="font-semibold text-slate-800 mb-1">Reproducibility gate (CV)</h3>
        <p>매 trial 은 N=3 측정 후 CV(throughput) 계산. CV ≥ 0.10 이면 N=5 escalate. 그래도 ≥ 0.10 이면 노이즈로 분류, score 신뢰도 낮음 표시. SLO (TTFT/E2E) 위반 시 즉시 score=0.</p>
      </div>
    </div>
    <p class="mt-4 text-xs text-slate-400">
      자세한 수식·코드 위치는 <code>docs/search_principles.md</code> 참조.
    </p>
  </details>

  <details class="bg-white border border-slate-200 rounded-lg p-5">
    <summary class="cursor-pointer text-sm font-semibold text-slate-700">Raw study JSON</summary>
    <pre class="mt-3 text-xs bg-slate-50 p-3 rounded overflow-auto">{{ study_json }}</pre>
  </details>

</main>

<footer class="max-w-7xl mx-auto px-6 py-6 text-xs text-slate-400">
  Generated by <code>bench dashboard build</code>. JSON: <a href="../data/studies_index.json" class="hover:underline">studies_index</a> · <a href="../data/throughput_vs_latency.json" class="hover:underline">tvl</a> · <a href="../data/perf_history.json" class="hover:underline">perf_history</a>
</footer>

<script>
const STUDY = {{ study_json|safe }};

// Configurable scatter: X / Y axes pulled from any metric.workload key
// in TrialPoint.metrics.

function collectMetricKeys() {
  const keys = new Set();
  STUDY.points.forEach(p => {
    Object.keys(p.metrics || {}).forEach(k => keys.add(k));
  });
  return [...keys].sort();
}

function fillSelect(id, options, defaultKey) {
  const sel = document.getElementById(id);
  options.forEach(k => {
    const o = document.createElement('option');
    o.value = k;
    o.textContent = k;
    if (k === defaultKey) o.selected = true;
    sel.appendChild(o);
  });
}

function pickDefault(keys, candidates) {
  for (const c of candidates) {
    const hit = keys.find(k => k.startsWith(c + '.'));
    if (hit) return hit;
  }
  return keys[0];
}

function getValue(p, key) {
  return p.metrics ? p.metrics[key] : undefined;
}

let chart;
function render() {
  const xKey = document.getElementById('x-axis').value;
  const yKey = document.getElementById('y-axis').value;

  const points = STUDY.points
    .filter(p => getValue(p, xKey) != null && getValue(p, yKey) != null)
    .map(p => ({x: getValue(p, xKey), y: getValue(p, yKey), seq: p.seq, trial_id: p.trial_id}));

  if (points.length === 0) {
    document.getElementById('tput-empty').classList.remove('hidden');
    document.getElementById('throughput-vs-ttft').classList.add('hidden');
    if (chart) { chart.destroy(); chart = null; }
    return;
  }
  document.getElementById('tput-empty').classList.add('hidden');
  document.getElementById('throughput-vs-ttft').classList.remove('hidden');

  if (chart) chart.destroy();

  // Pareto overlay — only when X/Y match ttft_p99 / throughput axis.
  const datasets = [{
    label: 'trials',
    data: points,
    backgroundColor: points.map((p, i) => `hsla(220, 80%, ${30 + Math.round(50 * i / Math.max(1, points.length - 1))}%, 0.75)`),
    pointRadius: 6,
  }];
  const xLooksLikeTtft = /^ttft_p99(\.|_)/i.test(xKey);
  const yLooksLikeTput = /throughput/i.test(yKey);
  if (xLooksLikeTtft && yLooksLikeTput && Array.isArray(STUDY.pareto_front) && STUDY.pareto_front.length > 0) {
    datasets.push({
      label: 'Pareto front',
      type: 'line',
      data: STUDY.pareto_front.map(p => ({x: p.x, y: p.y, seq: p.seq, trial_id: p.trial_id})),
      borderColor: 'rgb(225, 29, 72)',
      backgroundColor: 'rgba(225, 29, 72, 0.85)',
      pointRadius: 5,
      pointStyle: 'rectRot',
      showLine: true,
      fill: false,
      borderWidth: 2,
      order: 0,
    });
  }

  chart = new Chart(document.getElementById('throughput-vs-ttft'), {
    type: 'scatter',
    data: {datasets},
    options: {
      scales: {
        x: {title: {display: true, text: xKey}},
        y: {title: {display: true, text: yKey}},
      },
      plugins: {
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const p = ctx.raw;
              const lbl = ctx.dataset.label || '';
              return `${lbl} seq=${p.seq} trial=${(p.trial_id||'').slice(0, 10)}… ${xKey}=${p.x.toFixed(3)} ${yKey}=${p.y.toFixed(3)}`;
            }
          }
        }
      }
    }
  });
}

const allKeys = collectMetricKeys();
if (allKeys.length === 0) {
  document.getElementById('tput-empty').classList.remove('hidden');
  document.getElementById('throughput-vs-ttft').classList.add('hidden');
} else {
  // Defaults: prefer ttft_p99 for X (lower=better), throughput for Y (higher=better)
  const xDefault = pickDefault(allKeys, ['ttft_p99', 'e2e_p99', 'tpot_p99']);
  const yDefault = pickDefault(allKeys, ['throughput_tok_avg', 'throughput_avg', 'throughput_tok', 'score']);
  fillSelect('x-axis', allKeys, xDefault);
  fillSelect('y-axis', allKeys, yDefault);
  document.getElementById('x-axis').addEventListener('change', render);
  document.getElementById('y-axis').addEventListener('change', render);
  render();
}

// line: score over trials
const trace = STUDY.points
  .filter(p => p.score != null)
  .sort((a, b) => a.seq - b.seq)
  .map(p => ({x: p.seq, y: p.score}));

if (trace.length === 0) {
  document.getElementById('score-empty').classList.remove('hidden');
  document.getElementById('score-trace').classList.add('hidden');
} else {
  // running best
  const direction = STUDY.direction;
  const better = (a, b) => direction === 'maximize' ? a > b : a < b;
  let best = trace[0].y;
  const running = trace.map(p => {
    if (better(p.y, best)) best = p.y;
    return {x: p.x, y: best};
  });
  new Chart(document.getElementById('score-trace'), {
    type: 'line',
    data: {
      datasets: [
        {label: 'score', data: trace, showLine: false, pointRadius: 4, pointBackgroundColor: 'rgba(100,116,139,0.6)'},
        {label: 'running best', data: running, borderColor: 'rgb(37,99,235)', backgroundColor: 'transparent', stepped: true, pointRadius: 0},
      ],
    },
    options: {
      scales: {
        x: {title: {display: true, text: 'trial seq'}, type: 'linear'},
        y: {title: {display: true, text: STUDY.metric_name}},
      },
    }
  });
}

// === Axis importance bar chart (RandomForest) ===
const importance = Array.isArray(STUDY.axis_importance) ? STUDY.axis_importance : [];
if (importance.length > 0 && document.getElementById('axis-importance-bar')) {
  new Chart(document.getElementById('axis-importance-bar'), {
    type: 'bar',
    data: {
      labels: importance.map(r => r.axis),
      datasets: [{
        label: 'importance',
        data: importance.map(r => r.importance),
        backgroundColor: importance.map(r => r.recommendation === 'drop' ? 'rgba(148,163,184,0.7)' : 'rgba(37,99,235,0.85)'),
      }],
    },
    options: {
      indexAxis: 'y',
      plugins: {
        legend: {display: false},
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const r = importance[ctx.dataIndex];
              return `${r.axis}: ${r.importance.toFixed(4)} (${r.recommendation})`;
            }
          }
        },
      },
      scales: {
        x: {title: {display: true, text: 'feature_importance (sum of one-hot levels)'}},
      },
    }
  });
}

// === Parallel coordinates — vanilla canvas drawing ===
function drawParallelCoords(canvasId, topK, maxAxes) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const completed = STUDY.points
    .filter(p => p.score != null)
    .sort((a, b) => STUDY.direction === 'maximize' ? b.score - a.score : a.score - b.score);
  if (completed.length < 2) return;

  // Discover axes (preserve first-seen order)
  const axesSeen = [];
  completed.forEach(p => {
    Object.keys(p.params || {}).forEach(k => {
      if (!axesSeen.includes(k)) axesSeen.push(k);
    });
  });
  const axes = axesSeen.slice(0, maxAxes);
  if (axes.length < 2) return;

  // Per-axis normalization
  const norm = {};   // axis -> array of [0,1]
  const labels = {}; // axis -> {kind: 'num'|'cat', tick0, tick1}
  axes.forEach(k => {
    const vals = completed.map(p => (p.params || {})[k]);
    const allNum = vals.every(v => typeof v === 'number');
    if (allNum) {
      const lo = Math.min(...vals), hi = Math.max(...vals);
      const rng = (hi - lo) || 1;
      norm[k] = vals.map(v => (v - lo) / rng);
      labels[k] = {kind: 'num', tick0: lo, tick1: hi};
    } else {
      const order = [];
      vals.forEach(v => { const s = String(v); if (!order.includes(s)) order.push(s); });
      const n = Math.max(1, order.length - 1);
      const idx = Object.fromEntries(order.map((v, i) => [v, i / n]));
      norm[k] = vals.map(v => idx[String(v)]);
      labels[k] = {kind: 'cat', tick0: order[0], tick1: order[order.length - 1]};
    }
  });

  // Layout
  const PAD_L = 60, PAD_R = 30, PAD_T = 28, PAD_B = 80;
  const innerW = W - PAD_L - PAD_R;
  const innerH = H - PAD_T - PAD_B;
  const xs = axes.map((_, i) => PAD_L + (innerW * i) / Math.max(1, axes.length - 1));

  // Vertical axis lines
  ctx.strokeStyle = '#94a3b8';
  ctx.lineWidth = 1;
  xs.forEach(x => {
    ctx.beginPath();
    ctx.moveTo(x, PAD_T);
    ctx.lineTo(x, PAD_T + innerH);
    ctx.stroke();
  });

  // Y(value) helper: 1 → top, 0 → bottom
  const yPos = v => PAD_T + innerH * (1 - v);

  // Draw rest first (behind)
  ctx.lineWidth = 0.7;
  ctx.strokeStyle = 'rgba(148,163,184,0.45)';
  for (let i = topK; i < completed.length; i++) {
    ctx.beginPath();
    axes.forEach((k, ai) => {
      const y = yPos(norm[k][i]);
      if (ai === 0) ctx.moveTo(xs[ai], y); else ctx.lineTo(xs[ai], y);
    });
    ctx.stroke();
  }
  // Draw top-K (foreground), color = viridis-like
  ctx.lineWidth = 2;
  for (let i = 0; i < Math.min(topK, completed.length); i++) {
    const t = topK > 1 ? i / (topK - 1) : 0;
    const hue = 250 - 200 * t;   // 250 (purple) → 50 (yellow-green)
    const sat = 75, lit = 50 - 5 * t;
    ctx.strokeStyle = `hsl(${hue}, ${sat}%, ${lit}%)`;
    ctx.beginPath();
    axes.forEach((k, ai) => {
      const y = yPos(norm[k][i]);
      if (ai === 0) ctx.moveTo(xs[ai], y); else ctx.lineTo(xs[ai], y);
    });
    ctx.stroke();
  }

  // Axis labels (rotated)
  ctx.fillStyle = '#475569';
  ctx.font = '11px ui-sans-serif, system-ui';
  ctx.textAlign = 'right';
  axes.forEach((k, i) => {
    ctx.save();
    ctx.translate(xs[i], PAD_T + innerH + 8);
    ctx.rotate(-Math.PI / 5);
    ctx.fillText(k, 0, 0);
    ctx.restore();
  });

  // Tick labels min/max per axis
  ctx.font = '9px ui-monospace, monospace';
  ctx.textAlign = 'right';
  ctx.fillStyle = '#64748b';
  axes.forEach((k, i) => {
    const lab = labels[k];
    const lo = typeof lab.tick0 === 'number' ? lab.tick0.toPrecision(3) : String(lab.tick0).slice(0, 8);
    const hi = typeof lab.tick1 === 'number' ? lab.tick1.toPrecision(3) : String(lab.tick1).slice(0, 8);
    ctx.fillText(hi, xs[i] - 3, PAD_T + 4);
    ctx.fillText(lo, xs[i] - 3, PAD_T + innerH + 2);
  });

  // Legend
  ctx.textAlign = 'left';
  ctx.font = '11px ui-sans-serif, system-ui';
  ctx.fillStyle = '#1e293b';
  ctx.fillText(`top-${Math.min(topK, completed.length)} highlighted · ${completed.length} completed trials`, PAD_L, 18);
  for (let i = 0; i < Math.min(topK, completed.length, 5); i++) {
    const t = topK > 1 ? i / (topK - 1) : 0;
    const hue = 250 - 200 * t;
    ctx.fillStyle = `hsl(${hue}, 75%, ${50 - 5 * t}%)`;
    ctx.fillRect(W - 230 + 36 * i, 6, 16, 5);
    ctx.fillStyle = '#475569';
    ctx.font = '10px ui-monospace, monospace';
    ctx.fillText(`#${i + 1} ${completed[i].score.toFixed(2)}`, W - 230 + 36 * i, 22);
    ctx.font = '11px ui-sans-serif, system-ui';
  }
}

(function setupParallelCoords() {
  const canvas = document.getElementById('parallel-coords');
  if (!canvas) return;
  const topkInput = document.getElementById('pc-topk');
  const maxaxInput = document.getElementById('pc-maxax');
  const refresh = () => {
    const k = Math.max(1, parseInt(topkInput.value || '5', 10));
    const m = Math.max(2, parseInt(maxaxInput.value || '14', 10));
    drawParallelCoords('parallel-coords', k, m);
  };
  topkInput.addEventListener('input', refresh);
  maxaxInput.addEventListener('input', refresh);
  refresh();
})();

// === Axis-pair score heatmap ===
(function setupAxisPairHeatmap() {
  const canvas = document.getElementById('axis-pair-heatmap');
  if (!canvas) return;
  const completed = STUDY.points.filter(p => p.score != null);
  if (completed.length < 2) return;

  const axesSeen = [];
  completed.forEach(p => Object.keys(p.params || {}).forEach(k => {
    if (!axesSeen.includes(k)) axesSeen.push(k);
  }));
  if (axesSeen.length < 2) return;

  const xSel = document.getElementById('hm-x');
  const ySel = document.getElementById('hm-y');
  axesSeen.forEach(a => {
    [xSel, ySel].forEach(sel => {
      const o = document.createElement('option');
      o.value = a;
      o.textContent = a;
      sel.appendChild(o);
    });
  });
  xSel.value = axesSeen[0];
  ySel.value = axesSeen[Math.min(1, axesSeen.length - 1)];

  function uniqueValues(axis) {
    const seen = [];
    completed.forEach(p => {
      const v = (p.params || {})[axis];
      const k = typeof v === 'number' ? v : String(v);
      if (!seen.some(x => x === k || (typeof x === 'number' && x === v))) {
        seen.push(k);
      }
    });
    seen.sort((a, b) => {
      const an = typeof a === 'number' ? a : NaN;
      const bn = typeof b === 'number' ? b : NaN;
      if (!isNaN(an) && !isNaN(bn)) return an - bn;
      return String(a).localeCompare(String(b));
    });
    return seen;
  }

  let hoverInfo = '';
  function draw() {
    const xAxis = xSel.value, yAxis = ySel.value;
    const xs = uniqueValues(xAxis), ys = uniqueValues(yAxis);
    const cells = {};   // 'x|y' -> {sum, n, scores}
    completed.forEach(p => {
      const xv = (p.params || {})[xAxis];
      const yv = (p.params || {})[yAxis];
      const k = `${typeof xv === 'number' ? xv : String(xv)}|${typeof yv === 'number' ? yv : String(yv)}`;
      const c = cells[k] = cells[k] || {sum: 0, n: 0, max: -Infinity, min: Infinity};
      c.sum += p.score;
      c.n += 1;
      c.max = Math.max(c.max, p.score);
      c.min = Math.min(c.min, p.score);
    });
    const vals = Object.values(cells).map(c => c.sum / c.n);
    if (vals.length === 0) return;
    const lo = Math.min(...vals), hi = Math.max(...vals);
    const rng = (hi - lo) || 1;
    const dir = STUDY.direction || 'maximize';

    const ctx = canvas.getContext('2d');
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);

    const PAD_L = 110, PAD_R = 30, PAD_T = 30, PAD_B = 80;
    const innerW = W - PAD_L - PAD_R;
    const innerH = H - PAD_T - PAD_B;
    const cw = innerW / xs.length;
    const ch = innerH / ys.length;

    // Cell rects
    ys.forEach((yv, yi) => {
      xs.forEach((xv, xi) => {
        const k = `${xv}|${yv}`;
        const c = cells[k];
        const x = PAD_L + xi * cw, y = PAD_T + yi * ch;
        if (!c) {
          ctx.fillStyle = '#f1f5f9';
          ctx.fillRect(x, y, cw - 1, ch - 1);
          return;
        }
        const v = c.sum / c.n;
        let t = (v - lo) / rng;
        if (dir === 'minimize') t = 1 - t;
        // viridis-like
        const hue = 250 - 200 * t;
        const lightness = 92 - t * 50;
        ctx.fillStyle = `hsl(${hue}, 70%, ${lightness}%)`;
        ctx.fillRect(x, y, cw - 1, ch - 1);
        // text
        ctx.fillStyle = t > 0.5 ? '#fff' : '#1e293b';
        ctx.font = '11px ui-monospace, monospace';
        ctx.textAlign = 'center';
        ctx.fillText(v.toFixed(2), x + cw / 2, y + ch / 2 - 1);
        ctx.font = '9px ui-monospace, monospace';
        ctx.fillText(`n=${c.n}`, x + cw / 2, y + ch / 2 + 11);
      });
    });

    // X axis labels
    ctx.fillStyle = '#475569';
    ctx.font = '11px ui-sans-serif, system-ui';
    ctx.textAlign = 'center';
    xs.forEach((xv, xi) => {
      ctx.save();
      ctx.translate(PAD_L + xi * cw + cw / 2, PAD_T + innerH + 8);
      ctx.rotate(-Math.PI / 7);
      ctx.fillText(String(xv), 0, 6);
      ctx.restore();
    });
    // Y axis labels
    ctx.textAlign = 'right';
    ys.forEach((yv, yi) => {
      ctx.fillText(String(yv), PAD_L - 6, PAD_T + yi * ch + ch / 2 + 4);
    });
    // Title
    ctx.textAlign = 'left';
    ctx.font = '11px ui-sans-serif, system-ui';
    ctx.fillStyle = '#1e293b';
    ctx.fillText(`${xAxis} (X) × ${yAxis} (Y) — score (avg per cell)`, PAD_L, 18);
    ctx.fillStyle = '#94a3b8';
    ctx.font = '10px ui-monospace, monospace';
    ctx.fillText(hoverInfo, PAD_L + 380, 18);
  }

  // Hover for detail
  canvas.addEventListener('mousemove', (ev) => {
    const r = canvas.getBoundingClientRect();
    const sx = canvas.width / r.width;
    const sy = canvas.height / r.height;
    const xAxis = xSel.value, yAxis = ySel.value;
    const xs = uniqueValues(xAxis), ys = uniqueValues(yAxis);
    const PAD_L = 110, PAD_R = 30, PAD_T = 30, PAD_B = 80;
    const innerW = canvas.width - PAD_L - PAD_R;
    const innerH = canvas.height - PAD_T - PAD_B;
    const cw = innerW / xs.length;
    const ch = innerH / ys.length;
    const mx = (ev.clientX - r.left) * sx;
    const my = (ev.clientY - r.top) * sy;
    const xi = Math.floor((mx - PAD_L) / cw);
    const yi = Math.floor((my - PAD_T) / ch);
    if (xi >= 0 && xi < xs.length && yi >= 0 && yi < ys.length) {
      hoverInfo = `${xAxis}=${xs[xi]} ${yAxis}=${ys[yi]}`;
    } else {
      hoverInfo = '';
    }
    draw();
  });
  canvas.addEventListener('mouseleave', () => { hoverInfo = ''; draw(); });
  xSel.addEventListener('change', draw);
  ySel.addEventListener('change', draw);
  draw();
})();
</script>
</body>
