#!/usr/bin/env bash
# Auto-generated by `bench search export {{ study_id }} --winner top-1`.
#
# Study     : {{ study_name }}  ({{ study_id }})
# Created   : {{ created_at }}
# Strategy  : {{ strategy }}
# Direction : {{ direction }}, Metric: {{ metric_name }}
# Winner    : {{ trial_id }}  (seq={{ seq }}, score={{ score }})
#
# 본 스크립트는 winner trial 의 params 를 endpoint 에 적용 + (옵션) helmfile
# 재배포 + smoke 측정. dry-run 으로 먼저 plan 을 확인한 뒤 --apply 로 실행.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../../../.." && pwd)"
ENDPOINT="${ENDPOINT:-{{ endpoint_path }}}"
ADAPTER="${ADAPTER:-{{ adapter }}}"

usage() {
  cat <<EOF
$0 [--dry-run|--apply]
  --dry-run   render values overlay only, no kubectl/vllm restart (default)
  --apply     run helmfile apply / vllm_restart.sh + verify

env vars:
  ENDPOINT    endpoint YAML path (default: $ENDPOINT)
  ADAPTER     local-vllm | llmd-k8s (default: $ADAPTER)
EOF
}

MODE="${1:---dry-run}"
case "$MODE" in
  --dry-run|--apply) ;;
  *) usage; exit 2 ;;
esac

cd "$REPO_ROOT"

echo "[winner-apply] study={{ study_id }}  trial={{ trial_id }}  score={{ score }}"
echo "[winner-apply] params:"
cat <<'PARAMS'
{{ params_json_pretty }}
PARAMS

if [ "$ADAPTER" = "local-vllm" ]; then
  echo "[winner-apply] adapter=local-vllm → write engine_args back to endpoint, then vllm_restart.sh"
  if [ "$MODE" = "--apply" ]; then
    .venv/bin/python -m bench.cli search apply-params \
      --endpoint "$ENDPOINT" \
      --params-json "$REPO_ROOT/$(dirname "$0")/params.json"
    bash scripts/vllm_restart.sh "$ENDPOINT"
  else
    echo "[winner-apply] (dry-run) would: vllm_restart.sh $ENDPOINT"
  fi
elif [ "$ADAPTER" = "llmd-k8s" ]; then
  echo "[winner-apply] adapter=llmd-k8s → helmfile -f peer/.. --state-values-file overlay apply"
  OVERLAY="$REPO_ROOT/$(dirname "$0")/values-overlay.yaml"
  if [ "$MODE" = "--apply" ]; then
{% if helmfile_root %}
    helmfile -f "{{ helmfile_root }}/{{ helmfile_file }}" \
             --environment "{{ environment }}" \
             --selector "{{ selector }}" \
             --state-values-file "$OVERLAY" \
             apply
{% if deployment_names %}
{% for dep in deployment_names %}
    kubectl -n "{{ namespace }}" rollout status deployment/{{ dep }} --timeout=300s
{% endfor %}
{% endif %}
{% else %}
    echo "ERROR: this winner has no helmfile_overrides recorded; manual apply needed."
    exit 1
{% endif %}
  else
    echo "[winner-apply] (dry-run) overlay at: $OVERLAY"
    cat "$OVERLAY"
  fi
else
  echo "[winner-apply] unknown ADAPTER=$ADAPTER (use local-vllm or llmd-k8s)"
  exit 2
fi

echo "[winner-apply] done."
