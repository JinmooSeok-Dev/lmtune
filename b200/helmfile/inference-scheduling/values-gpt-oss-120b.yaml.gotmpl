# gpt-oss-120b — B200 16-GPU baseline (TEMPLATED, TP=8 × DP=2, monolithic)
#
# OpenAI gpt-oss-120b (2025-08 공개): 117B MoE (128 experts × top-4, 5.1B active),
# MXFP4 native weight (~63GB). ungated.
#
# Default: TP=8 × DP=2 = 16 GPU 전부 사용.
#   - 노드별 1 replica (8 GPU 통째 NVLink/NVSwitch)
#   - cross-node RDMA 안 거침 (각 replica self-contained)
#   - P/D disaggregation 비활성 (현재 NIXL 미정상)
#
# 후속 study 에서 b3_parallelism axis 로 sweep:
#   - TP=2 × DP=8, TP=4 × DP=4 (replicas 우위)
#   - wide-EP (DP=8 × EP=8) — wide-ep-lws path 별도 helmfile
#
# search space (b3_parallelism.yaml) 가 tp/dp/ep 를 sample 하면 LLMDK8sAdapter 가
# .StateValues.ms-infsch.parallelism / .replicas 로 inject → trial 마다 chart redeploy.

{{- $release := "ms-infsch" -}}
{{- $sv := index .StateValues $release | default dict -}}
{{- $vllmArgs := index $sv "vllmArgs" | default dict -}}
{{- /* lmtune b3 search-space (tp/dp) 가 inject 하는 parallelism/replicas. 미주입 시
      hardcoded baseline (TP=8 × DP=2) 사용. axis 활성화 시 trial 마다 chart redeploy. */}}
{{- $svDecode := index $sv "decode" | default dict -}}
{{- $svPar := index $svDecode "parallelism" | default dict -}}
{{- $tp := index $svPar "tensor" | default 8 -}}
{{- $rep := index $svDecode "replicas" | default 2 -}}
{{- /* R24 + R25: pp/dcp axis 도입. nvidia.com/gpu = (tp × pp). DCP 는 TP group
      안에서 KV 분산이라 추가 GPU 안 씀 (parallel.py:649). PCP 는 R25 로
      제거 (vllm 0.17.1 backend 어느 것도 supports_pcp=True 가 아님,
      backend.py:647 base False, 어느 subclass 도 override 안 함 →
      cp_utils.py:38 assert crash). 미주입 시 default 1 로 backward-compat. */}}
{{- $pp := default 1 (index $vllmArgs "pipeline-parallel-size") -}}
{{- $totalGpu := mul $tp $pp -}}

multinode: false

modelArtifacts:
  uri: "hf://openai/gpt-oss-120b"
  size: 80Gi
  name: "openai/gpt-oss-120b"
  labels:
    llm-d.ai/inference-serving: "true"
    llm-d.ai/inferenceServing: "true"
    llm-d.ai/guide: "b200-gpt-oss-120b"
    llm-d.ai/hardware-variant: "b200"
    llm-d.ai/accelerator-vendor: "nvidia"
    llm-d.ai/model: "gpt-oss-120b"

routing:
  proxy:
    enabled: false
    targetPort: 8000
  servicePort: 8000

# P/D disaggregation 비활성 — 현재 NIXL 미정상 + monolithic 이 단순.
# chart default 가 prefill.create=true 라 명시 false 필요.
prefill:
  create: false

decode:
  parallelism:
    tensor: {{ $tp }}     # TP: lmtune StateValues 우선, default=8 (pod 1개 8 GPU NVLink)
  create: true
  replicas: {{ $rep }}    # DP: lmtune StateValues 우선, default=2 (2 노드 × 1 replica)
  monitoring:
    podmonitor:
      enabled: false
  # 노드별 1 replica 강제 — 두 replica 가 같은 노드에 몰리면 NVLink 경합
  topologySpreadConstraints:
    - maxSkew: 1
      topologyKey: kubernetes.io/hostname
      whenUnsatisfiable: DoNotSchedule
      labelSelector:
        matchLabels:
          llm-d.ai/role: decode
          llm-d.ai/model: gpt-oss-120b
  containers:
    - name: "vllm"
      image: vllm/vllm-openai:v0.17.1
      modelCommand: vllmServe
      args:
        {{- /* tensor-parallel-size 는 chart 가 decode.parallelism.tensor 에서 자동 inject.
              여기서 또 emit 하면 --tensor-parallel-size 가 두 번 들어가 vllm 이 reject. */}}
        {{- /* max-model-len: gpt-oss-120b native 131072. B200 16-GPU (TP=8 × DP=2) 에서
              MXFP4 weight (~63GB / 8 GPU = ~8GB/GPU) 후 KV cache 여유 충분. 32K 로 baseline. */}}
        {{- $defaults := dict
              "max-num-seqs" 128
              "max-model-len" 32768
              "gpu-memory-utilization" 0.90
              "dtype" "bfloat16"
              "kv-cache-dtype" "auto"
        }}
        {{- $merged := mergeOverwrite (deepCopy $defaults) $vllmArgs }}
        {{- range $k, $v := $merged }}
        {{- if kindIs "bool" $v }}
        {{- if $v }}
        - "--{{ $k }}"
        {{- end }}
        {{- else }}
        - "--{{ $k }}"
        - {{ $v | quote }}
        {{- end }}
        {{- end }}
      resources:
        requests:
          nvidia.com/gpu: {{ $totalGpu | quote }}   # = TP × PP × PCP (DCP 는 TP group 안)
          cpu: "32"
          memory: 384Gi
        limits:
          nvidia.com/gpu: {{ $totalGpu | quote }}
          cpu: "64"
          memory: 512Gi
      env:
        - name: VLLM_LOGGING_LEVEL
          value: "INFO"
        # NCCL: 8-GPU NVLink/NVSwitch 활용 (NVLS in-network reduction)
        - name: NCCL_NVLS_ENABLE
          value: "1"
        - name: NCCL_DEBUG
          value: "WARN"
