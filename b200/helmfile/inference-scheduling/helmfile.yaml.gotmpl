# b200/helmfile/inference-scheduling/helmfile.yaml.gotmpl
#
# B200 16-GPU 클러스터 — well-lit path #1 (inference-scheduling)
# 사용법:
#   NS=b200-infsch helmfile -f b200/helmfile/inference-scheduling/helmfile.yaml.gotmpl apply
#
# selector:
#   --selector role=smoke   → values-llama-3.1-8b-smoke.yaml (B0)
#   --selector role=base    → values-qwen3-235b-tp2-dp4.yaml (B1)
#
# 모델 전환:
#   B200_MODEL_VALUES=values-gpt-oss-20b.yaml.gotmpl \
#     helmfile -f b200/helmfile/inference-scheduling/helmfile.yaml.gotmpl apply
#   미설정 시 default = values-llama-3.1-8b-smoke.yaml.gotmpl. 새 모델 추가는
#   values-<model>.yaml.gotmpl 1개 + endpoint YAML 1개로 끝 (helmfile 본체 무수정).
#
# Self-contained: peer repo 참조 없이 OCI chart 직접 사용.

environments:
  default:
    values:
      - provider:
          name: none

---

{{- $ns := .Namespace | default (env "NS") | default "b200-infsch" -}}
{{- $rn := (env "RELEASE_NAME_POSTFIX") | default "infsch" -}}

repositories:
  - name: llm-d-modelservice
    url: https://llm-d-incubation.github.io/llm-d-modelservice/
  - name: llm-d-infra
    url: https://llm-d-incubation.github.io/llm-d-infra/

releases:
  - name: {{ printf "infra-%s" $rn | quote }}
    namespace: {{ $ns }}
    chart: llm-d-infra/llm-d-infra
    version: v1.4.0
    installed: true
    labels:
      type: infrastructure
      kind: inference-stack
      role: smoke
    values:
      - gateway:
          # provider 가 default 'istio' 면 chart 가 Istio Telemetry/DestinationRule 을 렌더 →
          # k3s 에 Istio CRD 가 없을 경우 helm diff 단계에서 실패. agentgateway provider 로
          # 두어 Istio 의존을 끊는다. README 에 'agentgateway' 가 standalone 옵션으로 명시.
          provider: agentgateway
          gatewayClassName: agentgateway
          gatewayParameters:
            istio:
              accessLogging: false

  - name: {{ printf "gaie-%s" $rn | quote }}
    namespace: {{ $ns }}
    chart: oci://registry.k8s.io/gateway-api-inference-extension/charts/inferencepool
    version: v1.5.0
    installed: true
    needs:
      - {{ printf "infra-%s" $rn | quote }}
    values:
      - values-gaie.yaml
    labels:
      kind: inference-stack
      role: smoke

  - name: {{ printf "ms-%s" $rn | quote }}
    namespace: {{ $ns }}
    chart: llm-d-modelservice/llm-d-modelservice
    version: v0.4.12
    installed: true
    needs:
      - {{ printf "infra-%s" $rn | quote }}
      - {{ printf "gaie-%s" $rn | quote }}
    values:
      - ../base/values-b200-common.yaml.gotmpl
      - {{ env "B200_MODEL_VALUES" | default "values-llama-3.1-8b-smoke.yaml.gotmpl" }}
    set:
      # smoke: 모니터링 비활성 (B0 단계)
      - name: "decode.monitoring.podmonitor.enabled"
        value: false
    # llm-d-modelservice v0.4.12 가 spec.template.spec.runtimeClassName 를 expose 안 해서
    # NHN k3s (default runtime=runc + RuntimeClass nvidia) 환경에선 GPU pod 에 libcuda
    # 가 주입되지 않는다. post-renderer 가 모든 Deployment 에 runtimeClassName=nvidia 주입.
    postRenderer: ../_postrender/postrender.sh
    labels:
      kind: inference-stack
      role: smoke
