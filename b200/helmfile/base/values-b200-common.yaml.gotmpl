# values-b200-common.yaml.gotmpl
#
# B200 16-GPU 클러스터 위에서 모든 well-lit-path helmfile 이 상속받는 공통 overlay.
# peer repo 의 values 파일들과 helm `--values` 로 합쳐 적용한다.
#
# 적용 방식:
#   helmfile -f b200/helmfile/<path>/helmfile.yaml.gotmpl --state-values-file b200/helmfile/base/values-b200-common.yaml.gotmpl apply
#
# 또는 phase 별 helmfile.yaml.gotmpl 의 releases[].values 에 base 를 먼저 두고
# path 별 override 를 뒤에 붙이는 패턴으로 사용.

# ---------------- 공통 컨테이너 보안/리소스 패턴 ------------------------------
common:
  runtimeClassName: nvidia              # NVIDIA Container Runtime 강제
  imagePullPolicy: IfNotPresent          # 첫 풀 이후 빠른 재사용
  terminationGracePeriodSeconds: 600    # 대형 모델 종료 시간

  securityContext:
    runAsNonRoot: false                  # vLLM 일부 mmap 동작 위해 false 허용 (이슈 시 SCC 조정)
    allowPrivilegeEscalation: false
    capabilities:
      add: ["IPC_LOCK"]                  # RDMA pinned memory 필수
      drop: ["ALL"]

  resources:
    # 기본값: 모델별 helmfile 에서 override
    limits:
      nvidia.com/gpu: 1
      cpu: "16"
      memory: 64Gi
    requests:
      nvidia.com/gpu: 1
      cpu: "4"
      memory: 32Gi

  # /dev/shm 부족 방지 — NCCL/torch.distributed 필수
  shm:
    medium: Memory
    sizeLimit: 32Gi

  # vLLM 의 일반적인 환경변수 (B200 + RDMA 친화)
  env:
    - name: VLLM_LOGGING_LEVEL
      value: "INFO"
    - name: VLLM_USE_TRITON_FLASH_ATTN
      value: "1"
    # llm-d-cuda 이미지가 RHEL 계열인데 nvidia-container-toolkit 가 libcuda 를
    # /usr/lib/x86_64-linux-gnu (Debian multiarch) 로 inject. RHEL ld 는 그 path 를
    # default 에 안 넣어 Triton 의 cuda_utils.c gcc compile 에서 -l:libcuda.so.1
    # link fail. compile-time ld search path 보강.
    - name: LIBRARY_PATH
      value: "/usr/local/cuda/compat:/usr/lib/x86_64-linux-gnu:/usr/lib64"
    - name: NCCL_IB_DISABLE
      value: "0"                         # IB 켬 (RDMA 환경)
    - name: NCCL_NET_GDR_LEVEL
      value: "5"                         # GPUDirect RDMA 우선
    - name: NCCL_DEBUG
      value: "WARN"
    - name: NCCL_SOCKET_IFNAME
      value: "^docker,lo"                # docker/loopback 제외
    - name: TORCH_NCCL_BLOCKING_WAIT
      value: "1"

  # 노드 분산 — 같은 노드 다중 replica 회피 (multi-node 실험 시 필수)
  topologySpreadConstraints:
    - maxSkew: 1
      topologyKey: kubernetes.io/hostname
      whenUnsatisfiable: DoNotSchedule
      labelSelector:
        matchLabels:
          app.kubernetes.io/component: model-server

  # readiness/liveness — 대형 모델 부팅 보호 startupProbe 필수
  startupProbe:
    httpGet:
      path: /health
      port: 8000
    failureThreshold: 60                  # 60 * 10s = 10 min
    periodSeconds: 10
  readinessProbe:
    httpGet:
      path: /v1/models
      port: 8000
    periodSeconds: 5
    failureThreshold: 3
  livenessProbe:
    httpGet:
      path: /health
      port: 8000
    periodSeconds: 30
    failureThreshold: 3

# ---------------- B200 어셈블리 가정 -----------------------------------------
b200:
  hbm_per_gpu_gb: 180
  total_gpu: 16
  gpu_per_node: 8
  num_nodes: 2
  fabric: rdma                            # rdma | tcp — probe 결과로 갱신
  cuda_version: "12.6"                    # B200 sm_100 최소 요구
  nccl_min: "2.23"

# ---------------- 이미지 default ---------------------------------------------
# v0.7.0-rc.2 는 빌드 결함 (cu13 base + cu12 vllm._C wheel ABI mismatch,
# ldd 결과 libcudart.so.12 not found). v0.6.0 의 ldd 는 정상 (cu129 base
# + cu12 wheel + cu12 torch 일관). 처음 본 Triton/gcc 실패는 다른 원인의
# cascade 로 추정 (RDMA NCCL env smoke 충돌 가능성 — 별도 검증).
image:
  llmd:
    cuda: ghcr.io/llm-d/llm-d-cuda:v0.6.0
    routing_sidecar: ghcr.io/llm-d/llm-d-routing-sidecar:v0.7.1
    inference_scheduler: ghcr.io/llm-d/llm-d-inference-scheduler:v0.5.1
  pull_secret_name: ""                    # private registry 사용 시 secret 이름

# ---------------- 모니터링 ---------------------------------------------------
monitoring:
  podmonitor:
    enabled: true                         # llm-d-monitoring 가 설치돼 있으면 Prometheus 가 수집
